# OpenAI (krävs för chat, embeddings och sammanfattning)
OPENAI_API_KEY=sk-...

# Billiga standardvärden (byt vid behov)
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Valfritt: proxy / Azure OpenAI-kompatibel endpoint
# OPENAI_BASE_URL=https://api.openai.com/v1

# --- Begränsa kostnad för summarize-agenten (valfritt) ---
# STUDYAI_SUMMARY_CHUNK_CHARS=4500
# STUDYAI_SUMMARY_MAX_CHUNKS=8
# STUDYAI_SUMMARY_MAX_TOKENS_CHUNK=420
# STUDYAI_SUMMARY_MAX_TOKENS_FILE=900
# STUDYAI_SUMMARY_MAX_TOKENS_FINAL=4096
